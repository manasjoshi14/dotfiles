{
    "filesystem":
    {
        "allowWrite":
        [
            ".",
            "~/.npm/**",
            "~/.cache/pip/**",
            "~/.cache/uv/**",
            "~/.cargo/**",
            "~/.pnpm-store/**",
            "~/.cache/yarn/**",
            "~/.local/share/pnpm/**",
            "~/go/pkg/**",
            ".",
            "src/",
            "test/",
            "/tmp"
        ],
        "allowUnlink":
        [
            ".",
            "~/.npm/**",
            "~/.cache/pip/**",
            "~/.cache/uv/**",
            "~/.cargo/**",
            "~/.pnpm-store/**",
            "~/.cache/yarn/**",
            "~/.local/share/pnpm/**",
            "~/go/pkg/**"
        ],
        "denyWrite":
        [
            ".env",
            ".env.*",
            "secrets",
            "secrets.*",
            "credentials",
            "credentials.*",
            "*.key",
            "*.pem",
            "~/.srt/srt-settings.json",
            "~/.srt-settings.json"
        ],
        "denyRead":
        [
            "~/.ssh",
            ".env",
            ".env.*",
            "secrets",
            "secrets.*",
            "credentials",
            "credentials.*",
            "*.key",
            "*.pem"
        ]
    },
    "ignoreViolations":
    {
        "*":
        [
            "/usr/bin",
            "/System"
        ],
        "git push":
        [
            "/usr/bin/nc"
        ],
        "npm":
        [
            "/private/tmp"
        ]
    },
    "enableWeakerNetworkIsolation": true,
    "network":
    {
        "allowLocalBinding": false,
        "defaultPolicy": "deny",
        "allowUnixSockets":
        [
            "/var/run/docker.sock"
        ],
        "allowedDomains":
        [
            "github.com",
            "*.github.com",
            "lfs.github.com",
            "api.github.com",
            "gist.github.com",
            "raw.githubusercontent.com",
            "objects.githubusercontent.com",
            "npmjs.org",
            "*.npmjs.org",
            "registry.npmjs.org",
            "pypi.org",
            "*.pypi.org",
            "files.pythonhosted.org",
            "crates.io",
            "*.crates.io",
            "static.crates.io",
            "pkg.go.dev",
            "proxy.golang.org",
            "sum.golang.org"
        ]
    }
}
